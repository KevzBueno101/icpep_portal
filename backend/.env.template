# Copy this file to `.env` and fill in your values.
# DO NOT commit `.env` to git.

# Django
DEBUG=False
SECRET_KEY=<generate-a-strong-secret-key-for-production>

# Allowed hosts (your Render backend domain)
ALLOWED_HOSTS=your-backend.onrender.com

# Database (Render PostgreSQL connection string)
DB_NAME=<your_database_name>
DB_USER=<your_db_user>
DB_PASSWORD=<your_db_password>
DB_HOST=<your_db_host>
DB_PORT=5432

# Redis (Render Redis — for WebSocket channels)
REDIS_URL=redis://<your-redis-host>:6379/0

# Cloudinary (for production media/image storage)
CLOUDINARY_CLOUD_NAME=<your_cloud_name>
CLOUDINARY_API_KEY=<your_api_key>
CLOUDINARY_API_SECRET=<your_api_secret>

# CORS — Your Vercel frontend URL (comma-separated if multiple)
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Supabase (for announcements / legacy storage)
SUPABASE_URL=<your_supabase_url>
SUPABASE_KEY=<your_supabase_key>

# Frontend URL — used in password reset email links
FRONTEND_URL=https://your-frontend.vercel.app

# Gmail SMTP — used to send password reset emails
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
